# ==== Telegram ====
TELEGRAM_BOT_TOKEN=123456:REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_BOT_USERNAME=your_bot_username
# Comma-separated Telegram user IDs that get admin rights
ADMIN_TELEGRAM_IDS=5095749754
# Public https URL where the Mini App frontend is served (set in @BotFather /setmenubutton)
MINI_APP_URL=https://example.com
# Bot update mode: "polling" (dev) or "webhook" (prod)
BOT_MODE=polling
BOT_WEBHOOK_URL=https://example.com/bot/webhook
BOT_WEBHOOK_SECRET=change_me_webhook_secret
BOT_WEBHOOK_PORT=8081

# ==== Database ====
DB_NAME=footycards
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ==== Backend ====
# Random 32+ byte secret used to sign admin JWTs
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=720
# true only for local development: lets the frontend send an "X-Dev-Mode: true"
# header instead of real Telegram initData, authenticating as a fake dev user
DEV_MODE=true
DEV_USER_TELEGRAM_ID=999000001
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIMEZONE=Europe/Moscow
STARTING_BALANCE=500
BACKEND_PORT=8000

# ==== Frontend ====
VITE_API_URL=http://localhost:8000/api/v1
VITE_STATIC_URL=http://localhost:8000/static
FRONTEND_PORT=5173

# ==== Nginx (production) ====
NGINX_PORT=80
